# Algorand — AlgoNode free tier (no API key required)
ALGOD_URL=https://testnet-api.algonode.cloud:443
ALGOD_TOKEN=
INDEXER_URL=https://testnet-idx.algonode.cloud:443
INDEXER_TOKEN=

# Network
ALGO_NETWORK=testnet

# Delegation Registry (deploy with: npx tsx scripts/deploy-registry.ts)
# Requires DEPLOYER_MNEMONIC (25-word Algorand testnet mnemonic) for the deploy script.
REGISTRY_APP_ID=0

# Reputation Contract (deploy with: npx tsx scripts/deploy-reputation.ts)
# Requires DEPLOYER_MNEMONIC (25-word Algorand testnet mnemonic) for the deploy script.
REPUTATION_APP_ID=0

# Operator wallet — signs /delegate and /revoke transactions at runtime.
# Set to a 25-word Algorand mnemonic that has been pre-funded with ALGO
# for transaction fees. Use a secret manager (KMS / Vault / sealed-secret),
# never commit. See docs/security/operator-wallet.md.
OPERATOR_MNEMONIC=

# Deployer wallet — used only by scripts/deploy-registry.ts and
# scripts/deploy-reputation.ts. Must hold ≥0.1 ALGO for the create + fund
# transactions. Not used by the running service.
DEPLOYER_MNEMONIC=

# x402 Monetization (https://x402.org)
X402_ENABLED=false
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAYMENT_RECIPIENT=
X402_NETWORK=eip155:84532

# Rate limiting. See docs/operations/rate-limiting.md.
RATE_LIMIT_MAX=600                       # requests per IP per minute
RATE_LIMIT_TRUSTED_IPS=                  # comma-separated CIDRs/IPs exempted
RATE_LIMIT_PERSISTENCE_PATH=data/rate-limit.json

# System exposure cap. See docs/operations/system-exposure.md.
EXPOSURE_PERSISTENCE_PATH=data/system-exposure.json

# Request timeout (per upstream call to Algorand or x402 facilitator)
REQUEST_TIMEOUT_MS=30000

# Load testing — set to 1 to disable rate limiting (NEVER in production)
LOAD_TEST_MODE=0

# CORS (comma-separated origins, or * for all)
CORS_ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=info
LOG_FILE=
LOG_ERROR_FILE=
