# Algorand — AlgoNode free tier (no API key required)
ALGOD_URL=https://testnet-api.algonode.cloud:443
ALGOD_TOKEN=
INDEXER_URL=https://testnet-idx.algonode.cloud:443
INDEXER_TOKEN=

# Network
ALGO_NETWORK=testnet

# Delegation Registry (deploy with: npx tsx scripts/deploy-registry.ts)
REGISTRY_APP_ID=0

# Reputation Contract (deploy with: npx tsx scripts/deploy-reputation.ts)
REPUTATION_APP_ID=0

# x402 Monetization (https://x402.org)
X402_ENABLED=false
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAYMENT_RECIPIENT=
X402_NETWORK=eip155:84532

# CORS (comma-separated origins, or * for all)
CORS_ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=info
LOG_FILE=
LOG_ERROR_FILE=
