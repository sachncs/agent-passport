# ──────────────────────────────────────────────────────────────────
# Service
# ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development      # development | production | test

# ──────────────────────────────────────────────────────────────────
# Algorand — AlgoNode free tier (no API key required)
# ──────────────────────────────────────────────────────────────────
ALGOD_URL=https://testnet-api.algonode.cloud:443
ALGOD_TOKEN=
INDEXER_URL=https://testnet-idx.algonode.cloud:443
INDEXER_TOKEN=
ALGO_NETWORK=testnet

# ──────────────────────────────────────────────────────────────────
# Smart contracts (deploy with: npm run deploy-registry / deploy-reputation)
# DEPLOYER_MNEMONIC is consumed only by the deploy scripts, not the service.
# ──────────────────────────────────────────────────────────────────
REGISTRY_APP_ID=0
REPUTATION_APP_ID=0

# ──────────────────────────────────────────────────────────────────
# Operator wallet — signs /delegate and /revoke at runtime.
# NEVER commit this file. In production, load from KMS / Vault / sealed
# secret (see docs/security/operator-wallet.md). When unset, /delegate,
# /revoke, and /reputation/record degrade to off-chain-only.
# ──────────────────────────────────────────────────────────────────
OPERATOR_MNEMONIC=
DEPLOYER_MNEMONIC=

# ──────────────────────────────────────────────────────────────────
# x402 pay-per-query (https://x402.org). Disabled by default.
# ──────────────────────────────────────────────────────────────────
X402_ENABLED=false
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAYMENT_RECIPIENT=
X402_NETWORK=eip155:84532

# ──────────────────────────────────────────────────────────────────
# Rate limiting. See docs/operations/rate-limiting.md.
# ──────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=600                       # requests per IP per minute
RATE_LIMIT_TRUSTED_IPS=                  # comma-separated exact IPs exempted
RATE_LIMIT_PERSISTENCE_PATH=data/rate-limit.json

# ──────────────────────────────────────────────────────────────────
# System exposure cap. See docs/operations/system-exposure.md.
# ──────────────────────────────────────────────────────────────────
EXPOSURE_PERSISTENCE_PATH=data/system-exposure.json

# ──────────────────────────────────────────────────────────────────
# Per-request timeout (Algorand and x402 facilitator calls)
# ──────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000

# ──────────────────────────────────────────────────────────────────
# Load testing — set to 1 to disable rate limiting (NEVER in production)
# ──────────────────────────────────────────────────────────────────
LOAD_TEST_MODE=0

# ──────────────────────────────────────────────────────────────────
# CORS. "*" allows any origin (no credentials). For production, set an
# explicit comma-separated origin list (e.g. "https://app.example.com").
# ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*

# ──────────────────────────────────────────────────────────────────
# Logging — JSON to stdout (default) or to the paths below
# ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info            # debug | info | warn | error
LOG_FILE=
LOG_ERROR_FILE=
