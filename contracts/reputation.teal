// Agent Passport — Reputation Layer
// Stateful Algorand smart contract for recording observable behavior events.
//
// Global State:
//   admin — address of the contract admin
//   total_events — count of all events recorded
//
// Box Storage (per wallet):
//   Key: "rep:" + wallet(32) + ":" + event_type(1)
//   Value: count(8 bytes, uint64) + total_amount(8 bytes, uint64) = 16 bytes
//
// Event types: p=payment, u=purchase, d=dispute, r=refund, e=endorsement, s=service
//
// Methods:
//   record(wallet, event_type_char, amount) — record a reputation event

#pragma version 10

txn ApplicationID
int 0
==
bnz handle_create

txn OnCompletion
int NoOp
==
bnz handle_noop

txn OnCompletion
int DeleteApplication
==
bnz handle_delete

txn OnCompletion
int UpdateApplication
==
bnz handle_update

txn OnCompletion
int OptIn
==
bnz handle_optin

txn OnCompletion
int CloseOut
==
bnz handle_closeout

err

// ─── CREATE ────────────────────────────────────────────────────
handle_create:
  byte "admin"
  txn Sender
  app_global_put
  byte "total_events"
  int 0
  app_global_put
  int 1
  return

handle_delete:
  byte "admin"
  app_global_get
  txn Sender
  ==  assert
  int 1
  return

handle_update:
  byte "admin"
  app_global_get
  txn Sender
  ==  assert
  int 1
  return

handle_optin:
  int 1
  return

handle_closeout:
  int 1
  return

// ─── NOOP ──────────────────────────────────────────────────────
handle_noop:
  txn NumAppArgs
  int 0
  >  bnz route_method
  err

route_method:
  byte "record"
  txna ApplicationArgs 0
  ==  bnz method_record

  byte "admin"
  txna ApplicationArgs 0
  ==  bnz method_update_admin

  err

// ─── record(wallet, event_type_char, amount) ───────────────────
// Accounts[0] = target wallet
// ApplicationArgs[0] = "record"
// ApplicationArgs[1] = event type char (p/u/d/r/e/s)
// ApplicationArgs[2] = amount (uint64, microAlgo)
//
// Authorization:
//   Self-reported events (p/u/d/r/s): sender must be the target wallet
//   Endorsements (e): anyone can endorse another wallet
method_record:
  txn NumAppArgs
  int 3
  ==  assert

  txn NumAccounts
  int 1
  >=  assert

  // Check if this is an endorsement (event type = "e")
  txna ApplicationArgs 1
  byte "e"
  ==

  bnz method_record_endorsement

  // ── Self-reported event: sender must be target ──
  txn Sender
  txna Accounts 0
  ==  assert
  bnz method_record_common

method_record_endorsement:
  // ── Endorsement: anyone can endorse ──
  // Fall through to common recording logic

method_record_common:

  // Build box key: "rep:" + wallet(32) + ":" + event_type_char(1)
  byte "rep:"
  txna Accounts 0
  concat
  byte ":"
  concat
  txna ApplicationArgs 1
  concat

  // Check if box exists
  dup
  box_len
  int 0
  >  bnz record_update

  // ── New box: create with count=1, amount=event_amount ──
  int 1
  itob
  txna ApplicationArgs 2
  btoi
  itob
  concat
  box_put

  // Increment total_events
  byte "total_events"
  byte "total_events"
  app_global_get
  int 1
  +  app_global_put

  int 1
  return

record_update:
  // Stack: box_key
  // Read old value
  dup
  box_get
  swap
  pop
  // Stack: old_value (16 bytes)

  // Parse old count (first 8 bytes)
  dup
  int 0
  int 8
  substring3
  btoi
  // Stack: old_value, old_count

  // Increment count
  int 1
  +
  itob
  // Stack: old_value, new_count_bytes

  // Parse old amount (bytes 8-16)
  swap
  // Stack: new_count_bytes, old_value
  dup
  int 8
  int 16
  substring3
  btoi
  // Stack: new_count_bytes, old_value, old_amount

  // Add new amount
  txna ApplicationArgs 2
  btoi
  +
  itob
  // Stack: new_count_bytes, old_value, new_amount_bytes

  // Rebuild: new_count(8) + new_amount(8)
  // Drop old_value
  pop
  // Stack: new_count_bytes, new_amount_bytes
  concat
  // Stack: new_value (16 bytes)

  // Write box (rebuild key)
  byte "rep:"
  txna Accounts 0
  concat
  byte ":"
  concat
  txna ApplicationArgs 1
  concat
  // Stack: new_value, box_key
  box_put

  // Increment total_events
  byte "total_events"
  byte "total_events"
  app_global_get
  int 1
  +  app_global_put

  int 1
  return

// ─── update_admin(new_admin) ───────────────────────────────────
method_update_admin:
  txn NumAppArgs
  int 1
  ==  assert
  txn NumAccounts
  int 1
  ==  assert
  byte "admin"
  app_global_get
  txn Sender
  ==  assert
  byte "admin"
  txna Accounts 0
  app_global_put
  int 1
  return
