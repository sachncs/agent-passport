{
  "name": "agent-passport",
  "version": "0.1.0",
  "type": "module",
  "description": "Stateless trust scoring, delegation, credit, sybil, reputation, and underwriting for AI agents on Algorand",
  "license": "MIT",
  "author": {
    "name": "Sachin",
    "email": "sachncs@gmail.com"
  },
  "homepage": "https://github.com/sachn-cs/agent-passport#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sachn-cs/agent-passport.git"
  },
  "bugs": {
    "url": "https://github.com/sachn-cs/agent-passport/issues"
  },
  "keywords": [
    "algorand",
    "agent",
    "trust",
    "trust-scoring",
    "x402",
    "micropayments",
    "credit",
    "delegation",
    "sybil",
    "reputation",
    "underwriting",
    "fraud",
    "risk",
    "bazaar"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "src",
    "contracts",
    "scripts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --include 'src/**/*-integration.test.ts'",
    "score": "tsx scripts/score.ts",
    "delegate": "tsx scripts/delegate.ts",
    "deploy-registry": "tsx scripts/deploy-registry.ts",
    "check-counterparty": "tsx scripts/check-counterparty.ts",
    "estimate-credit": "tsx scripts/estimate-credit.ts",
    "check-sybil": "tsx scripts/check-sybil.ts",
    "deploy-reputation": "tsx scripts/deploy-reputation.ts",
    "record-reputation": "tsx scripts/record-reputation.ts",
    "check-reputation": "tsx scripts/check-reputation.ts",
    "dashboard": "echo 'Dashboard at http://localhost:3000/dashboard.html'",
    "benchmark": "vitest run src/__tests__/benchmark.test.ts --reporter=verbose"
  },
  "dependencies": {
    "@x402/core": "^2.16.0",
    "@x402/evm": "^2.16.0",
    "@x402/express": "^2.16.0",
    "algosdk": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "ws": "8.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
