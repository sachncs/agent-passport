          "name": "GET /discovery/search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/discovery/search?q=trust&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["discovery", "search"],
              "query": [
                { "key": "q", "value": "trust" },
                { "key": "limit", "value": "20" }
