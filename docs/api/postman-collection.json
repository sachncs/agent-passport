              "path": ["sybil-check"],
              "query": [{ "key": "wallet", "value": "{{wallet}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Passport",
      "item": [
        {
          "name": "GET /passport",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/passport?wallet={{wallet}}",
              "host": ["{{baseUrl}}"],
              "path": ["passport"],
              "query": [{ "key": "wallet", "value": "{{wallet}}" }]
