            "url": {
              "raw": "{{baseUrl}}/verify?wallet={{wallet}}",
              "host": ["{{baseUrl}}"],
              "path": ["verify"],
              "query": [{ "key": "wallet", "value": "{{wallet}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "On-chain (requires REGISTRY_APP_ID and OPERATOR_MNEMONIC)",
      "item": [
        {
          "name": "POST /delegate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sponsor\": \"{{wallet}}\",\n  \"agent\": \"ABCDEFGHIJKLMNOPQRSTUVWXYZ234567ABCDEFGHIJKLMNOPQRSTUVW234\",\n  \"amount\": 1000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/delegate",
              "host": ["{{baseUrl}}"],
              "path": ["delegate"]
            }
          }
        },
        {
          "name": "POST /revoke",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sponsor\": \"{{wallet}}\",\n  \"agent\": \"ABCDEFGHIJKLMNOPQRSTUVWXYZ234567ABCDEFGHIJKLMNOPQRSTUVW234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/revoke",
              "host": ["{{baseUrl}}"],
              "path": ["revoke"]
            }
          }
        }
      ]
    },
    {
      "name": "Discovery",
      "item": [
